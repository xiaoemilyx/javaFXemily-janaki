import javafx.animation.AnimationTimer;
import javafx.application.Application;
import javafx.scene.Scene;
import javafx.scene.layout.Pane;
import javafx.scene.paint.Color;
import javafx.scene.shape.Polygon;
import javafx.stage.Stage;

import java.util.ArrayList;
import java.util.List;
import java.util.Random;
import java.util.Scanner;

/* Mr. Turner ignore ts because we can't figure out how to work java fx
on another new java file so we're just using the ball demo */

public class BouncingBallsDemo extends Application {

    private static final int WIDTH = 800;
    private static final int HEIGHT = 600;
    private static final int STAR_COUNT = 10;
    private static double STAR_SIZE = 40;

    private final Random random = new Random();
    private final List<Star> stars = new ArrayList<>();

    public static void main(String[] args) {
        launch(args);
    }

    @Override
    public void start(Stage stage) {

        Scanner input = new Scanner(System.in);
        System.out.println("Enter a color: ");
        String colors = input.nextLine().toLowerCase();

        Pane root = new Pane();
        Scene scene = new Scene(root, WIDTH, HEIGHT, Color.BLACK);

        // Create stars
        for (int i = 0; i < STAR_COUNT; i++) {

            double x = random.nextDouble() * (WIDTH - 2 * STAR_SIZE) + STAR_SIZE;
            double y = random.nextDouble() * (HEIGHT - 2 * STAR_SIZE) + STAR_SIZE;

            double dx = random.nextDouble() * 4 - 2;
            double dy = random.nextDouble() * 4 - 2;

            Color color;

            if (colors.equals("red")) {
                color = Color.rgb(255, 0, 0);
            }
            else if (colors.equals("orange")) {
                color = Color.rgb(255, 165, 0);
            }
            else if (colors.equals("yellow")) {
                color = Color.rgb(255, 255, 0);
            }
            else if (colors.equals("green")) {
                color = Color.rgb(0, 255, 0);
            }
            else if (colors.equals("blue")) {
                color = Color.rgb(0, 0, 255);
            }
            else if (colors.equals("purple")) {
                color = Color.rgb(128, 0, 128);
            }
            else {
                color = randomColor();
            }

            Star star = new Star(x, y, dx, dy, STAR_SIZE, color);

            stars.add(star);
            root.getChildren().add(star.starShape);
        }

        // Animation loop
        AnimationTimer timer = new AnimationTimer() {
            @Override
            public void handle(long now) {

                for (Star star : stars) {
                    star.update();
                }

                checkCollisions();
            }
        };

        timer.start();

        stage.setTitle("Bouncing Stars");
        stage.setScene(scene);
        stage.show();
    }

    private void checkCollisions() {

        for (int i = 0; i < stars.size(); i++) {

            Star s1 = stars.get(i);

            for (int j = i + 1; j < stars.size(); j++) {

                Star s2 = stars.get(j);

                double dx = s1.x - s2.x;
                double dy = s1.y - s2.y;

                double distance = Math.sqrt(dx * dx + dy * dy);

                if (distance <= STAR_SIZE * 2) {

                    // swap velocities
                    double tempDx = s1.dx;
                    double tempDy = s1.dy;

                    s1.dx = s2.dx;
                    s1.dy = s2.dy;

                    s2.dx = tempDx;
                    s2.dy = tempDy;
                    
                    STAR_SIZE = STAR_SIZE/2;
                }
            }
        }
    }

    private Color randomColor() {

        return Color.color(
                random.nextDouble(),
                random.nextDouble(),
                random.nextDouble()
        );
    }

    private Polygon createStar(double centerX,
                               double centerY,
                               double size) {

        Polygon star = new Polygon();

        for (int i = 0; i < 10; i++) {

            double angle = Math.PI / 2 + i * Math.PI / 5;

            double radius;

            if (i % 2 == 0) {
                radius = size;
            }
            else {
                radius = size / 2;
            }

            double x = centerX + radius * Math.cos(angle);
            double y = centerY - radius * Math.sin(angle);

            star.getPoints().addAll(x, y);
        }

        return star;
    }

    private class Star {

        Polygon starShape;

        double x;
        double y;

        double dx;
        double dy;

        Star(double x,
             double y,
             double dx,
             double dy,
             double size,
             Color color) {

            this.x = x;
            this.y = y;

            this.dx = dx;
            this.dy = dy;

            starShape = createStar(x, y, size);

            starShape.setFill(color);
            starShape.setStroke(Color.BLACK);
        }

        void update() {

            x += dx;
            y += dy;

            // Bounce off walls
            if (x - STAR_SIZE < 0 ||
                x + STAR_SIZE > WIDTH) {

                dx *= -1;
            }

            if (y - STAR_SIZE < 0 ||
                y + STAR_SIZE > HEIGHT) {

                dy *= -1;
            }

            updatePosition();
        }

        void updatePosition() {

            Polygon newStar =
                    createStar(x, y, STAR_SIZE);

            starShape.getPoints().clear();

            starShape.getPoints().addAll(
                    newStar.getPoints()
            );
        }
    }
}
