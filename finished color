import javafx.animation.AnimationTimer;
import javafx.application.Application;
import javafx.scene.Scene;
import javafx.scene.layout.Pane;
import javafx.scene.paint.Color;
import javafx.scene.shape.Circle;
import javafx.stage.Stage;

import java.util.ArrayList;
import java.util.List;
import java.util.Random;
import java.util.Scanner; 

public class BouncingBallsDemo extends Application {

    private static final int WIDTH = 800;
    private static final int HEIGHT = 600;
    private static final int BALL_COUNT = 10;
    private static final double BALL_RADIUS = 20;

    private final Random random = new Random();
    private final List<Ball> balls = new ArrayList<>();

    public static void main(String[] args) {
        launch(args);
    }

    @Override
    public void start(Stage stage) {
        
        Scanner input = new Scanner(System.in);
        System.out.println("Enter a color: ");
        String colors = input.nextLine();
        
        Pane root = new Pane();
        Scene scene = new Scene(root, WIDTH, HEIGHT, Color.BLACK);

        // Create balls
        for (int i = 0; i < BALL_COUNT; i++) {
            double x = random.nextDouble() * (WIDTH - 2 * BALL_RADIUS) + BALL_RADIUS;
            double y = random.nextDouble() * (HEIGHT - 2 * BALL_RADIUS) + BALL_RADIUS;
            double dx = random.nextDouble() * 4 - 2; // velocity X
            double dy = random.nextDouble() * 4 - 2; // velocity Y
            
            Color color;

            if (colors.equals("red")) {
                color = Color.rgb(255, 0, 0);
            }
            else if (colors.equals("orange")) {
                color = Color.rgb(255, 165, 0);
            }
            else if (colors.equals("yellow")) {
                color = Color.rgb(255, 255, 0);
            }
            else if (colors.equals("green")) {
                color = Color.rgb(0, 255, 0);
            }
            else if (colors.equals("blue")) {
                color = Color.rgb(0, 0, 255);
            }
            else if (colors.equals("purple")) {
                color = Color.rgb(128, 0, 128);
            }
            else {
                color = randomColor(); // default color
            }
            Ball ball = new Ball(x, y, dx, dy, BALL_RADIUS, color);
            balls.add(ball);
            root.getChildren().add(ball.circle);
        }

        // Animation loop
        AnimationTimer timer = new AnimationTimer() {
            @Override
            public void handle(long now) {
                for (Ball ball : balls) {
                    ball.update();
                }
                checkCollisions();
            }
        };
        timer.start();

        stage.setTitle("Bouncing Balls Demo");
        stage.setScene(scene);
        stage.show();
    }

    private void checkCollisions() {
        for (int i = 0; i < balls.size(); i++) {
            Ball b1 = balls.get(i);
            for (int j = i + 1; j < balls.size(); j++) {
                Ball b2 = balls.get(j);
                double dx = b1.circle.getCenterX() - b2.circle.getCenterX();
                double dy = b1.circle.getCenterY() - b2.circle.getCenterY();
                double distance = Math.sqrt(dx * dx + dy * dy);
                if (distance <= BALL_RADIUS * 2) {
                    // Simple bounce effect by reversing velocities
                    double tempDx = b1.dx;
                    double tempDy = b1.dy;
                    b1.dx = b2.dx;
                    b1.dy = b2.dy;
                    b2.dx = tempDx;
                    b2.dy = tempDy;

                }
            }
        }
    }

    private Color randomColor() {
        return Color.color(random.nextDouble(), random.nextDouble(), random.nextDouble());
    }

    private class Ball {
        Circle circle;
        double dx;
        double dy;

        Ball(double x, double y, double dx, double dy, double radius, Color color) {
            this.circle = new Circle(x, y, radius, color);
            this.dx = dx;
            this.dy = dy;
        }

        void update() {
            double x = circle.getCenterX() + dx;
            double y = circle.getCenterY() + dy;

            // Bounce off walls
            if (x - BALL_RADIUS < 0 || x + BALL_RADIUS > WIDTH) {
                dx *= -1;
            }
            if (y - BALL_RADIUS < 0 || y + BALL_RADIUS > HEIGHT) {
                dy *= -1;
            }

            circle.setCenterX(circle.getCenterX() + dx);
            circle.setCenterY(circle.getCenterY() + dy);
        }
    }
}
